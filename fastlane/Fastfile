opt_out_usage
skip_docs

require 'fileutils'
require 'tmpdir'

default_platform(:android)

platform :android do
  private_lane :play_json_key do
    ENV.fetch('PLAY_JSON_KEY') do
      UI.user_error!(
        'Set PLAY_JSON_KEY to your local Google Play service-account JSON path.',
      )
    end
  end

  private_lane :play_metadata_path do
    source = File.expand_path('metadata/android', __dir__)
    destination_root = Dir.mktmpdir('custom-rr-play-metadata-')
    destination = File.join(destination_root, 'android')

    FileUtils.cp_r(source, destination)
    Dir.glob(File.join(destination, '*', 'changelogs')).each do |path|
      FileUtils.rm_rf(path)
    end

    destination
  end

  private_lane :play_track do
    ENV.fetch('PLAY_TRACK', 'alpha')
  end

  private_lane :play_version_code do
    Integer(ENV.fetch('PLAY_VERSION_CODE', '8'))
  end

  private_lane :play_aab_path do
    ENV.fetch('PLAY_AAB_PATH') do
      UI.user_error!(
        'Set PLAY_AAB_PATH to the built Play App Bundle (.aab) file path.',
      )
    end
  end

  private_lane :play_release_status do
    # 'draft' (default) uploads the bundle but leaves promoting it to you in
    # the Play Console. Set PLAY_RELEASE_STATUS=completed to push it straight
    # to the configured track (e.g. closed testing) for your testers.
    ENV.fetch('PLAY_RELEASE_STATUS', 'draft')
  end

  private_lane :play_release_name do
    # Optional override for the Play 'Release name' field. When unset, supply
    # falls back to the bundle's versionName. Set PLAY_RELEASE_NAME to e.g.
    # 'v1.2.0 (9) closed test' to control how the release is labelled.
    ENV.fetch('PLAY_RELEASE_NAME', nil)
  end

  desc 'Validate Google Play listing metadata without uploading app binaries or changelogs'
  lane :validate_play_metadata do
    supply(
      package_name: 'io.github.monsiu.custom_rr',
      metadata_path: play_metadata_path,
      json_key: play_json_key,
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_changelogs: true,
      track: play_track,
      version_code: play_version_code,
      validate_only: true,
    )
  end

  desc 'Upload Google Play listing metadata without uploading app binaries or changelogs'
  lane :upload_play_metadata do
    supply(
      package_name: 'io.github.monsiu.custom_rr',
      metadata_path: play_metadata_path,
      json_key: play_json_key,
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_changelogs: true,
      track: play_track,
      version_code: play_version_code,
      changes_not_sent_for_review: true,
    )
  end

  desc 'Upload a built Play App Bundle (.aab) to the configured track'
  lane :upload_play_bundle do
    # version_name fills the Play 'Release name'. Pointing supply at the real
    # metadata dir with skip_upload_changelogs: false prefills the release
    # notes from metadata/android/<locale>/changelogs/<versionCode>.txt while
    # leaving the store listing, images and screenshots untouched.
    supply(
      package_name: 'io.github.monsiu.custom_rr',
      aab: play_aab_path,
      json_key: play_json_key,
      track: play_track,
      release_status: play_release_status,
      version_name: play_release_name,
      metadata_path: File.expand_path('metadata/android', __dir__),
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      skip_upload_changelogs: false,
      changes_not_sent_for_review: true,
    )
  end
end
